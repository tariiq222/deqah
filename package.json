{
  "name": "deqah",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=dashboard",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:marketing": "turbo run dev --filter=@deqah/marketing",
    "dev:website": "turbo run dev --filter=@bespoke/sawa-website",
    "dev:mobile": "pnpm --filter=deqah-mobile run dev",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "openapi:sync": "pnpm --filter=backend run openapi:export && pnpm --filter=dashboard run openapi:generate",
    "test:report": "py scripts/qa/generate_html_report.py",
    "test:report:open": "py scripts/qa/generate_html_report.py && start data/test-reports/output/test-report.html",
    "kiwi:sync-manual": "node scripts/kiwi/kiwi-sync-manual-qa.mjs --plan",
    "brand:check": "node scripts/brand/check-brand-identity.mjs",
    "e2e:dashboard": "pnpm --filter dashboard e2e",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:check": "bash scripts/changeset-check.sh",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "husky": "^9.1.7",
    "react-test-renderer": "19.2.4",
    "turbo": "^2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "react-test-renderer": "19.2.4",
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7"
    }
  }
}
