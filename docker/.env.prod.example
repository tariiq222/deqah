# Deqah Production Environment — docker/.env.prod.example
#
# !! THIS FILE IS THE CANONICAL CHECKLIST FOR PRODUCTION DEPLOYMENT !!
#
# All keys marked [REQUIRED] must be set before the backend will boot.
# Keys marked [REQUIRED in prod] are enforced by Joi when NODE_ENV=production.
# Optional keys default to safe values if omitted.
#
# Copy to .env.prod (never commit .env.prod) and fill every [REQUIRED] value.
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod up -d
#
# Generate random secrets with:
#   openssl rand -base64 32   (for 32-byte keys, base64-encoded, length=44)
#   openssl rand -base64 64   (for JWT secrets)
#
# DRIFT CHECK: run `node scripts/ci/check-env-drift.mjs` to verify this file
# stays in sync with apps/backend/src/config/env.validation.ts.

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5100

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# [REQUIRED]
DATABASE_URL=postgresql://deqah:<password>@deqah-database-jeprin:5432/deqah

# ── Docker / Postgres container vars (used by docker-compose, not Joi) ────────
POSTGRES_USER=deqah
POSTGRES_PASSWORD=
POSTGRES_DB=deqah

# ── Redis ─────────────────────────────────────────────────────────────────────
# [REQUIRED]
REDIS_HOST=deqah-redis-lby5cy
# [REQUIRED]
REDIS_PORT=6379
# optional
REDIS_PASSWORD=

# ── MinIO (object storage) ───────────────────────────────────────────────────
# [REQUIRED]
MINIO_ENDPOINT=deqah-minio-w7ighg
# [REQUIRED]
MINIO_PORT=9000
# [REQUIRED]
MINIO_ACCESS_KEY=
# [REQUIRED]
MINIO_SECRET_KEY=
# [REQUIRED]
MINIO_BUCKET=deqah
MINIO_USE_SSL=false

# ── JWT (Identity) ────────────────────────────────────────────────────────────
# [REQUIRED] — generate: openssl rand -base64 64
JWT_ACCESS_SECRET=
# [REQUIRED] — generate: openssl rand -base64 64
JWT_REFRESH_SECRET=
# [REQUIRED in prod] — generate: openssl rand -base64 64
# Dedicated OTP secret — must differ from JWT_ACCESS_SECRET
JWT_OTP_SECRET=
# [REQUIRED] — generate: openssl rand -base64 64
JWT_CLIENT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_CLIENT_ACCESS_TTL=15m
JWT_CLIENT_REFRESH_TTL=7d

# ── Encryption keys (32 raw bytes, base64-encoded — ASCII length MUST be 44) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# [REQUIRED]
SMS_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
ZOOM_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
MOYASAR_TENANT_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
EMAIL_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED] — set RELAX_PROD_VALIDATION=true only during the initial boot window
# before Zoho credentials are available
ZOHO_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
TENANT_ENFORCEMENT=strict
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# ── Super-admin password ──────────────────────────────────────────────────────
# [REQUIRED in prod] — min 16 chars; banned values: Admin@2026, admin, password
SUPER_ADMIN_PASSWORD=

# ── CAPTCHA ───────────────────────────────────────────────────────────────────
# [REQUIRED in prod] — must be hcaptcha or turnstile (noop is forbidden in prod)
CAPTCHA_PROVIDER=hcaptcha
# [REQUIRED when CAPTCHA_PROVIDER=hcaptcha]
HCAPTCHA_SECRET=
# TURNSTILE_SECRET=  # required only when CAPTCHA_PROVIDER=turnstile

# ── Authentica (OTP SMS provider) ─────────────────────────────────────────────
# [REQUIRED in prod] — https://portal.authentica.sa/settings/apikeys/
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# ── Platform Moyasar (SaaS billing — charges tenants) ────────────────────────
# [REQUIRED in prod]
MOYASAR_PLATFORM_SECRET_KEY=sk_live_<your-key-here>
# [REQUIRED in prod]
MOYASAR_PLATFORM_WEBHOOK_SECRET=<your-webhook-secret-here>
SAAS_TRIAL_DAYS=14
SAAS_GRACE_PERIOD_DAYS=2
BILLING_CRON_ENABLED=true
PLATFORM_DEFAULT_PLAN_SLUG=BASIC

# ── Platform tax invoice metadata ─────────────────────────────────────────────
# [REQUIRED] — replace 300000000000003 with real ZATCA VAT before live invoices
PLATFORM_VAT_NUMBER=300000000000003
# [REQUIRED]
PLATFORM_COMPANY_NAME_AR=دقّة لتقنية المعلومات
# [REQUIRED]
PLATFORM_COMPANY_NAME_EN=Deqah Information Technology

# ── Public URLs ───────────────────────────────────────────────────────────────
# [REQUIRED in prod]
DASHBOARD_PUBLIC_URL=https://app.deqah.net
# [REQUIRED in prod]
API_PUBLIC_URL=https://api.deqah.net
# [REQUIRED in prod]
PUBLIC_WEBSITE_URL=https://deqah.net

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (dashboard + mobile)
CORS_ORIGINS=https://app.deqah.net,https://admin.deqah.net

# ── Super-admin host guard ────────────────────────────────────────────────────
# [REQUIRED in prod] — comma-separated; only these Host headers reach admin endpoints
ADMIN_HOSTS=admin.deqah.net

# ── Zoho (per-tenant invoicing integration) ───────────────────────────────────
# [REQUIRED in prod] — shared OAuth client for all tenants
# Set RELAX_PROD_VALIDATION=true to make optional during initial boot
ZOHO_OAUTH_CLIENT_ID=<your-zoho-client-id>
ZOHO_OAUTH_CLIENT_SECRET=<your-zoho-client-secret>
ZOHO_OAUTH_REDIRECT_URI=https://api.deqah.net/api/v1/integrations/zoho/callback
ZOHO_PLATFORM_ORGANIZATION_ID=
ZOHO_PLATFORM_REFRESH_TOKEN=
ZOHO_PLATFORM_DC=sa
ZOHO_PLATFORM_WEBHOOK_SECRET=
SMS_WEBHOOK_URL_BASE=https://api.deqah.net

# ── AI (optional) ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Firebase / FCM (push notifications — optional) ────────────────────────────
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── SMTP (optional — Resend or other provider) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@deqah.net

# ── Escape hatch ─────────────────────────────────────────────────────────────
# Set to true ONLY during initial boot window before Zoho/hCaptcha creds land.
# REMOVE once real credentials are populated — leaving this on weakens security.
# RELAX_PROD_VALIDATION=true

# ── Billing-cron kill-switch ──────────────────────────────────────────────────
# MUST NOT be set to true in production
THROTTLER_DISABLED=false

# ── Sentry (optional — leave blank until GlitchTip / Sentry Cloud is wired) ──
# SENTRY_DSN=

# ── Backup (VPS-level, used by scripts/backup-*.sh — not consumed by Joi) ────
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=
