# hCaptcha Site Key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# --- Sentry / GlitchTip error tracking ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=deqah-admin
SENTRY_URL=https://errors.webvue.pro/

# --- PostHog error tracking (browser-side) ---
# Leave empty to silently disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
