NEXT_PUBLIC_API_URL=http://localhost:5100
NEXT_PUBLIC_DEFAULT_ORG_ID=
# Optional: JSON map of hostname -> orgId
NEXT_PUBLIC_HOST_ORG_MAP=

# hCaptcha site key — get yours at https://dashboard.hcaptcha.com/
# In development, leave unset to use hCaptcha's public test key automatically.
# In production, this MUST be set to your real site key.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# --- Sentry / GlitchTip error tracking ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=deqah-website
SENTRY_URL=https://errors.webvue.pro/
