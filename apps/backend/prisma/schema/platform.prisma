// Platform BC — license validation, problem reports, integrations.
// SaaS-02g: ProblemReport, Integration scoped (NOT Organization/Membership/Vertical*).

enum ProblemReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ProblemReportType {
  BUG
  FEATURE_REQUEST
  OTHER
}

model ProblemReport {
  id             String              @id @default(uuid())
  organizationId String // SaaS-02g
  reporterId     String
  type           ProblemReportType
  title          String
  description    String
  status         ProblemReportStatus @default(OPEN)
  resolution     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([status])
}

model Integration {
  id             String   @id @default(uuid())
  organizationId String // SaaS-02g
  provider       String // now composite-unique per (orgId, provider)
  config         Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId])
}

// ─── Organization (SaaS-01) ──────────────────────────────────────────────────
// Top-level tenant. Every tenant-scoped row in every cluster will FK to this
// once Plan 02 rolls out. For now only User memberships reference it; the
// default org (id = DEFAULT_ORGANIZATION_ID env var) owns all historical data.

enum OrganizationStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  ARCHIVED
}

enum SuperAdminActionType {
  SUSPEND_ORG
  REINSTATE_ORG
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_ARCHIVE
  FEATURE_FLAG_UPDATE
  IMPERSONATE_START
  IMPERSONATE_END
  RESET_PASSWORD
  PLAN_CREATE
  PLAN_UPDATE
  PLAN_DELETE
  VERTICAL_CREATE
  VERTICAL_UPDATE
  VERTICAL_DELETE
  BILLING_REFUND
  BILLING_WAIVE_INVOICE
  BILLING_GRANT_CREDIT
  BILLING_CHANGE_PLAN
  BILLING_FORCE_CHARGE
  PLATFORM_SETTING_UPDATED
}

model Organization {
  id                    String             @id @default(uuid())
  slug                  String             @unique
  nameAr                String
  nameEn                String?
  status                OrganizationStatus @default(ACTIVE)
  verticalId            String?
  vertical              Vertical?          @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  trialEndsAt           DateTime?
  suspendedAt           DateTime?
  suspendedReason       String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  memberships     Membership[]
  invitations     Invitation[]
  subscription    Subscription?
  savedCards      SavedCard[]
  invoiceCounters OrganizationInvoiceCounter[]
  usageCounters   UsageCounter[]

  @@index([status])
  @@index([verticalId])
}

model ImpersonationSession {
  id               String    @id @default(cuid())
  superAdminUserId String
  targetUserId     String
  organizationId   String
  reason           String    @db.Text
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  expiresAt        DateTime
  endedReason      String?
  ipAddress        String
  userAgent        String    @db.Text
  createdAt        DateTime  @default(now())

  @@index([superAdminUserId])
  @@index([targetUserId])
  @@index([organizationId])
  @@index([expiresAt])
  @@index([endedAt])
}

model SuperAdminActionLog {
  id                     String               @id @default(cuid())
  superAdminUserId       String
  actionType             SuperAdminActionType
  organizationId         String?
  impersonationSessionId String?
  reason                 String?              @db.Text
  metadata               Json
  ipAddress              String
  userAgent              String               @db.Text
  createdAt              DateTime             @default(now())

  @@index([superAdminUserId])
  @@index([actionType])
  @@index([organizationId])
  @@index([impersonationSessionId])
  @@index([createdAt])
}

// ─── Membership (SaaS-01) ────────────────────────────────────────────────────
// Join table — a User can belong to N organizations with different roles in
// each. Existing JWT `role` claim becomes per-membership (Plan 02 wires this).

enum MembershipRole {
  OWNER
  ADMIN
  RECEPTIONIST
  ACCOUNTANT
  EMPLOYEE
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole @default(RECEPTIONIST)
  isActive       Boolean        @default(true)
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Per-membership display profile — overrides User defaults within this org.
  displayName String?
  jobTitle    String?
  avatarUrl   String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── Invitation (SaaS-06c) ───────────────────────────────────────────────────

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id              String           @id @default(uuid())
  organizationId  String
  email           String
  role            MembershipRole
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  invitedByUserId String
  acceptedAt      DateTime?
  revokedAt       DateTime?
  // Per-org display profile presets carried from invite into the Membership
  // when accepted. The recipient may overwrite later via membership-profile.
  displayName     String?
  jobTitle        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email, organizationId])
  @@index([status, expiresAt])
}

// ─── Vertical (SaaS-03) ──────────────────────────────────────────────────────
// Platform-level catalog of clinic verticals Deqah supports.

enum TemplateFamily {
  MEDICAL
  THERAPY
  CONSULTING
  SALON
  FITNESS
}

model Vertical {
  id             String         @id @default(uuid())
  slug           String         @unique
  nameAr         String
  nameEn         String
  templateFamily TemplateFamily
  descriptionAr  String?
  descriptionEn  String?
  iconUrl        String?
  sortOrder      Int            @default(0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  seedDepartments       VerticalSeedDepartment[]
  seedServiceCategories VerticalSeedServiceCategory[]
  terminologyOverrides  VerticalTerminologyOverride[]
  organizations         Organization[]

  @@index([templateFamily])
  @@index([isActive, sortOrder])
}

model VerticalSeedDepartment {
  id         String   @id @default(uuid())
  verticalId String
  vertical   Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  nameAr     String
  nameEn     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  seedCategories VerticalSeedServiceCategory[]

  @@unique([verticalId, nameAr])
  @@index([verticalId])
}

model VerticalSeedServiceCategory {
  id           String                  @id @default(uuid())
  verticalId   String
  vertical     Vertical                @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  departmentId String?
  department   VerticalSeedDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  nameAr       String
  nameEn       String
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([verticalId, nameAr])
  @@index([verticalId])
  @@index([departmentId])
}

model VerticalTerminologyOverride {
  id         String   @id @default(uuid())
  verticalId String
  vertical   Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  tokenKey   String
  valueAr    String
  valueEn    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([verticalId, tokenKey])
  @@index([verticalId])
}

// ─── Billing (SaaS-04) ───────────────────────────────────────────────────────
// Plan, SubscriptionInvoice = platform-level (Deqah's catalog / receivables).
// Subscription, UsageRecord   = tenant-scoped (belong to an org).

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  DUE
  PAID
  FAILED
  VOID
}

enum UsageMetric {
  // Hard-capped (enforced by PlanLimitsGuard; no overage billing)
  BRANCHES
  EMPLOYEES
  // Metered overage (never blocked; billed at period end)
  BOOKINGS_PER_MONTH
  CLIENTS
  STORAGE_MB
}

model Plan {
  id               String   @id @default(uuid())
  /// Format enforced by DB CHECK "Plan_slug_format_chk": ^[A-Z][A-Z0-9_]{1,31}$
  slug             String   @unique
  nameAr           String
  nameEn           String
  priceMonthly     Decimal  @db.Decimal(12, 2)
  priceAnnual      Decimal  @db.Decimal(12, 2)
  currency         String   @default("SAR")
  moyasarProductId String? // optional future Moyasar native subscriptions
  // limits JSON shape:
  //   { maxBranches, maxEmployees,                         // hard-capped quotas (-1 = unlimited)
  //     maxBookingsPerMonth, maxClients, maxStorageMB,     // metered overage quotas (-1 = unlimited)
  //     overageRateBookings, overageRateClients, overageRateStorageGB, // SAR per unit above quota
  //     websiteEnabled, customDomainEnabled, chatbotEnabled, ratingsEnabled }
  limits           Json
  isActive         Boolean  @default(true)
  isVisible        Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions          Subscription[]
  scheduledSubscriptions Subscription[] @relation("SubscriptionScheduledPlan")
  versions               PlanVersion[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                           String             @id @default(uuid())
  organizationId               String             @unique // one active sub per org (SaaS-04 scoped)
  organization                 Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId                       String
  plan                         Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  planVersionId                String?
  planVersion                  PlanVersion?       @relation(fields: [planVersionId], references: [id], onDelete: Restrict)
  status                       SubscriptionStatus @default(TRIALING)
  billingCycle                 BillingCycle       @default(MONTHLY)
  currentPeriodStart           DateTime
  currentPeriodEnd             DateTime
  trialStartedAt               DateTime?
  trialEndsAt                  DateTime?
  trialExtendedBy              Int                @default(0)
  trialExtendedById            String?
  trialExtendedAt              DateTime?
  canceledAt                   DateTime?
  cancelReason                 String?
  cancelAtPeriodEnd            Boolean            @default(false)
  scheduledCancellationDate    DateTime?
  scheduledPlanId              String?
  scheduledPlan                Plan?              @relation("SubscriptionScheduledPlan", fields: [scheduledPlanId], references: [id], onDelete: SetNull)
  scheduledBillingCycle        BillingCycle?
  scheduledPlanChangeAt        DateTime?
  scheduledChangeBlockedReason String? // Set by cron when downgrade-safety check fails at swap-time
  apiAccessGraceUntil          DateTime? // set when API_ACCESS is revoked on downgrade; tenant keeps access until this date
  webhooksGraceUntil           DateTime? // set when WEBHOOKS is revoked on downgrade; tenant keeps access until this date
  pastDueSince                 DateTime? // set when ACTIVE → PAST_DUE; drives 2-day grace
  retryCount                   Int                @default(0) // analytics only; not used for state decisions
  maxRetries                   Int                @default(3) // charging attempts within grace window
  dunningRetryCount            Int                @default(0)
  nextRetryAt                  DateTime?
  moyasarCustomerRef           String? // Moyasar customer id
  moyasarCardTokenRef          String? // tokenized saved card
  moyasarSubscriptionRef       String? // reserved for future native recurring
  defaultSavedCardId           String?
  defaultSavedCard             SavedCard?         @relation("SubscriptionDefaultSavedCard", fields: [defaultSavedCardId], references: [id], onDelete: SetNull)
  lastPaymentAt                DateTime?
  lastFailureReason            String?
  notifiedTrialEndingAt        DateTime? // resend platform emails: dedupe trial-ending notifications
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  invoices     SubscriptionInvoice[]
  usageRecords UsageRecord[]
  dunningLogs  DunningLog[]

  @@index([planId])
  @@index([planVersionId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([cancelAtPeriodEnd, scheduledCancellationDate])
  @@index([scheduledPlanChangeAt])
  @@index([nextRetryAt])
}

model PlanVersion {
  id           String   @id @default(uuid())
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  version      Int
  priceMonthly Decimal  @db.Decimal(12, 2)
  priceAnnual  Decimal  @db.Decimal(12, 2)
  currency     String   @default("SAR")
  limits       Json
  createdAt    DateTime @default(now())

  subscriptions Subscription[]

  @@unique([planId, version])
  @@index([planId])
}

model SavedCard {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moyasarTokenId String       @unique
  last4          String
  brand          String
  expiryMonth    Int
  expiryYear     Int
  holderName     String?
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  defaultForSubscriptions Subscription[]        @relation("SubscriptionDefaultSavedCard")
  invoices                SubscriptionInvoice[]

  @@index([organizationId])
  @@index([organizationId, isDefault])
}

model SubscriptionInvoice {
  id               String                    @id @default(uuid())
  subscriptionId   String
  subscription     Subscription              @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  organizationId   String // denormalized for analytics; NOT SCOPED — this is Deqah's receivable
  amount           Decimal                   @db.Decimal(12, 2) // flat + Σ(overage)
  flatAmount       Decimal                   @db.Decimal(12, 2)
  overageAmount    Decimal                   @default(0) @db.Decimal(12, 2)
  // lineItems shape:
  //   [{ kind: 'FLAT_FEE', description, amount },
  //    { kind: 'OVERAGE', metric: 'BOOKINGS_PER_MONTH'|'CLIENTS'|'STORAGE_MB',
  //      included, used, overage, rate, amount }]
  lineItems        Json                      @default("[]")
  currency         String                    @default("SAR")
  status           SubscriptionInvoiceStatus @default(DRAFT)
  billingCycle     BillingCycle
  periodStart      DateTime
  periodEnd        DateTime
  dueDate          DateTime
  issuedAt         DateTime?
  paidAt           DateTime?
  moyasarPaymentId String?                   @unique
  savedCardId      String?
  savedCard        SavedCard?                @relation(fields: [savedCardId], references: [id], onDelete: SetNull)
  failureReason    String?
  attemptCount     Int                       @default(0)
  receiptUrl       String?
  pdfUrl           String?
  // SaaS-05c — admin billing oversight
  refundedAmount   Decimal?                  @db.Decimal(12, 2)
  refundedAt       DateTime?
  voidedReason     String?
  // Phase 7 — tenant invoice numbering, hash chain, and PDF storage.
  // invoiceNumber is unique per (organizationId, invoiceNumber) — sequences
  // reset annually per org so two orgs both have INV-{year}-000001.
  invoiceNumber    String?
  invoiceHash      String?
  previousHash     String?
  pdfStorageKey    String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  dunningLogs DunningLog[]

  @@unique([organizationId, invoiceNumber], name: "SubscriptionInvoice_org_number_uq")
  @@index([subscriptionId])
  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@index([organizationId, issuedAt])
}

// Phase 7 — per-organization invoice number sequence (yearly reset).
// Bug B5 (2026-05-03): this model IS in SCOPED_MODELS — even though writes
// happen only via the issue-invoice handler today, defense-in-depth requires
// the Prisma extension to inject the org filter so a future caller cannot
// accidentally read or update another tenant's `lastSequence`.
model OrganizationInvoiceCounter {
  organizationId String
  year           Int
  lastSequence   Int          @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, year])
  @@index([organizationId])
}

model DunningLog {
  id               String              @id @default(uuid())
  organizationId   String
  subscriptionId   String
  subscription     Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId        String
  invoice          SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  attemptNumber    Int
  status           String
  moyasarPaymentId String?
  failureReason    String?
  scheduledFor     DateTime
  executedAt       DateTime            @default(now())

  @@unique([invoiceId, attemptNumber])
  @@index([organizationId])
  @@index([subscriptionId])
  @@index([invoiceId])
}

// SaaS-05c — credit granted by super-admin, applied against next invoice.
// Platform-level (not tenant-scoped) — Deqah's liability to the tenant.
model BillingCredit {
  id                String    @id @default(uuid())
  organizationId    String
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("SAR")
  reason            String    @db.Text
  grantedByUserId   String
  grantedAt         DateTime  @default(now())
  consumedInvoiceId String?
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([organizationId, consumedAt])
  @@index([grantedByUserId])
}

model UsageRecord {
  id             String       @id @default(uuid())
  organizationId String // SaaS-04 scoped
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  metric         UsageMetric
  count          Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())

  @@unique([subscriptionId, metric, periodStart])
  @@index([organizationId])
  @@index([subscriptionId])
  @@index([metric])
}

// Platform-level webhook dedup. Intentionally NOT in SCOPED_MODELS — Moyasar webhooks belong to Deqah, not a tenant.
model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String // 'MOYASAR_PLATFORM' | 'MOYASAR_TENANT'
  eventId     String
  eventType   String
  receivedAt  DateTime  @default(now())
  payloadHash String
  processedAt DateTime?
  result      String? // 'processed' | 'skipped_duplicate' | 'error'

  @@unique([provider, eventId])
  @@index([receivedAt])
}

// Phase 5 — materialized quota counters. One row per (org, featureKey, period).
// monthly_bookings resets each calendar month (periodStart = 1st of month UTC).
// All other quantitative keys use EPOCH (1970-01-01) as their periodStart
// so they accumulate without resetting.
model UsageCounter {
  id             String   @id @default(uuid())
  organizationId String
  featureKey     String
  periodStart    DateTime
  value          Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureKey, periodStart])
  @@index([organizationId])
  @@index([featureKey])
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── RefundUsageRevertLog ─────────────────────────────────────────────────────
// Idempotency log for usage-counter decrements triggered by refunds. Each row
// records that a (refundRequestId, metric) pair has already been reverted, so
// re-firing the RefundCompletedEvent does NOT double-decrement the counter.
//
// One row per (refundRequestId, metric) is the unique constraint that guards
// against replays. The cluster owns this model because the decrement listener
// lives in `platform/billing/usage-counter/decrement-on-refund/`.

model RefundUsageRevertLog {
  id              String   @id @default(uuid())
  organizationId  String
  refundRequestId String
  metric          String
  amount          Int
  createdAt       DateTime @default(now())

  @@unique([refundRequestId, metric])
  @@index([organizationId])
  @@index([refundRequestId])
}
