# Deqah — Root .env.example
# Source of truth: apps/backend/src/config/env.validation.ts
# Regenerated: 2026-05-11 — do not edit by hand; sync from the Joi schema.

# --- Core Runtime ---
# Runtime environment. One of: development | test | staging | production.
NODE_ENV=development
# HTTP port the NestJS backend binds to.
PORT=5100
# Public origin of the backend API (used to build webhook URLs for Zoho, Moyasar, etc.).
# Must be HTTPS and internet-reachable in production. In dev use ngrok/cloudflared if
# you need real inbound webhooks; localhost is fine otherwise. # required in production
API_PUBLIC_URL=http://localhost:5100
# Convenience alias used by some internal code paths and the Docker compose stack.
# Keep in sync with API_PUBLIC_URL. # optional
BACKEND_URL=http://localhost:5100
# Public origin of the tenant dashboard app (Next.js on :5103). Used in emails,
# password-reset links, billing redirects. Must be HTTPS in production. # required in production
DASHBOARD_PUBLIC_URL=http://localhost:5103
# Convenience alias for DASHBOARD_PUBLIC_URL consumed by some service modules. # optional
DASHBOARD_URL=http://localhost:5103
# Public origin of the marketing/website app. Must be HTTPS in production. # required in production
PUBLIC_WEBSITE_URL=http://localhost:5106
# Convenience alias for PUBLIC_WEBSITE_URL. # optional
WEBSITE_URL=http://localhost:5106
# CORS — comma-separated list of allowed origins (no trailing slash). Leave blank in
# dev to allow all localhost. MUST be set in production to dashboard + mobile origins.
CORS_ORIGINS=http://localhost:5103,http://localhost:5104,http://localhost:5105,http://localhost:5106
# Comma-separated Host headers accepted by AdminHostGuard for the super-admin panel.
# In dev: Next.js admin (:5104) proxies to backend (:5100), so both must be listed.
# In prod: add your admin subdomain (e.g. admin.deqah.app). # required in production
ADMIN_HOSTS=localhost:5104,localhost:5100

# --- Database (Prisma + Postgres) ---
# Postgres connection string. In production MUST include connection_limit and
# pool_timeout query params, and MUST use the NOBYPASSRLS role (deqah_app), never
# the OWNER role (deqah). Dev points at the docker-compose Postgres on host port 5999.
# NOTE: this dev URL will be REJECTED in production by env.validation.ts — prod
# must use deqah_app + ?connection_limit=N&pool_timeout=N (see docs/operations/p0-rls-cutover.md).
DATABASE_URL=postgresql://deqah:deqah_dev_password@localhost:5999/deqah_dev?schema=public
# Optional override of the per-request DB user used by the RLS GUC interceptor.
# Defaults to the user embedded in DATABASE_URL. # optional
APP_DB_USER=deqah_app
# Password for APP_DB_USER when APP_DB_USER differs from the URL user. # optional
APP_DB_PASSWORD=dev-app-db-password-change-me
# Per-statement timeout in milliseconds, applied via SET statement_timeout. # optional
DB_STATEMENT_TIMEOUT_MS=30000
# Pool acquisition timeout in seconds (Prisma pool_timeout). # optional
DB_POOL_TIMEOUT_S=20
# Maximum Prisma connection-pool size per backend instance. # optional
DB_CONNECTION_LIMIT=10

# --- Redis (BullMQ + cache + token blacklist) ---
# Redis hostname. Docker compose maps redis:6379 to host port 5380.
REDIS_HOST=localhost
# Redis port. Use 5380 with the docker-compose dev stack.
REDIS_PORT=5380
# Optional Redis AUTH password. Blank for the dev stack. # optional
REDIS_PASSWORD=
# Logical Redis DB number (0-15). # optional
REDIS_DB=0

# --- MinIO (S3-compatible object storage) ---
# MinIO hostname. Docker compose exposes the API on host port 5200, console on 5201.
MINIO_ENDPOINT=localhost
# MinIO API port. Use 5200 with the docker-compose dev stack.
MINIO_PORT=5200
# MinIO access key (root user in dev).
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key. Banned in production: must NOT be 'minioadmin'.
MINIO_SECRET_KEY=minioadmin123
# Default bucket for tenant uploads (avatars, attachments, branding assets).
MINIO_BUCKET=deqah
# Set to true when MinIO/S3 is fronted by TLS. # optional
MINIO_USE_SSL=false
# Separate bucket for rendered invoice PDFs (Phase 7).
MINIO_INVOICE_BUCKET=deqah-invoices

# --- JWT (Identity BC) ---
# All four JWT secrets below MUST be regenerated before deploying to staging or
# production. The dev placeholders here all contain 'change-me' / 'dev-' and are
# rejected at boot when NODE_ENV=production by env.validation.ts.
# Backend access-token signing secret. Min 16 chars. Production rejects any value
# containing 'change-me', 'CHANGE_ME', 'REPLACE_ME', 'dev-', or 'sk_test_'.
JWT_ACCESS_SECRET=dev-jwt-access-secret-change-me-32c
# Access-token TTL (e.g. 15m, 1h). # optional
JWT_ACCESS_TTL=15m
# Reserved for future JWT-signed refresh tokens. Today refresh is opaque DB-stored
# (bcrypt selector). Min 16 chars; same placeholder rules as JWT_ACCESS_SECRET.
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me-32c
# Refresh-token TTL. # optional
JWT_REFRESH_TTL=30d
# Dedicated OTP-token secret. Required in production so a leaked OTP token cannot
# forge an access token. Falls back to JWT_ACCESS_SECRET in dev/test only.
JWT_OTP_SECRET=dev-jwt-otp-secret-change-me-32c
# Client-app (mobile + website) access-token secret. Separate namespace from staff JWTs.
JWT_CLIENT_ACCESS_SECRET=dev-jwt-client-access-secret-change-32c
# Client-app access-token TTL. # optional
JWT_CLIENT_ACCESS_TTL=15m
# Client-app refresh-token TTL. # optional
JWT_CLIENT_REFRESH_TTL=7d

# --- Encryption keys (per-tenant secrets at rest) ---
# All five keys must be 32 raw bytes, base64-encoded (ASCII length 44).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Wraps each tenant's SMS provider credentials (Unifonic / Taqnyat).
SMS_PROVIDER_ENCRYPTION_KEY=ZGV2LXNtcy1lbmNyeXB0aW9uLWtleS1jaGFuZ2VtZSE=
# Wraps each tenant's Zoom OAuth tokens.
ZOOM_PROVIDER_ENCRYPTION_KEY=ZGV2LXpvb20tZW5jcnlwdGlvbi1rZXktY2hhbmdlbWU=
# Wraps each tenant's Moyasar publishable + secret keys.
MOYASAR_TENANT_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAP8=
# Wraps each tenant's per-org SMTP credentials (EmailCredentialsService).
EMAIL_PROVIDER_ENCRYPTION_KEY=ZGV2LWVtYWlsLWVuY3J5cHRpb24ta2V5LWNoYW5nZSE=
# Wraps each tenant's Zoho OAuth refresh token + zoho_organization_id + webhook secret.
ZOHO_PROVIDER_ENCRYPTION_KEY=ZGV2LXpvaG8tZW5jcnlwdGlvbi1rZXktY2hhbmdlbWUhAA==

# --- Tenancy ---
# Multi-tenant enforcement mode (SaaS-02h):
#   strict     — platform default. Any scoped query without CLS org throws.
#   permissive — falls back to DEFAULT_ORGANIZATION_ID. Dev-only escape hatch.
#   off        — no scoping. Legacy single-tenant. NEVER in multi-tenant prod.
TENANT_ENFORCEMENT=strict
# Fallback organization ID used in permissive mode and seed scripts.
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
# Apex domain used by the subdomain resolver to derive the tenant slug from the
# Host header (e.g. sawa.<root> -> "sawa"). Dev defaults to "localhost" if blank.
# # required in production
PLATFORM_ROOT_DOMAIN=localhost
# Optional CSV merged with the built-in reserved-subdomains list. # optional
RESERVED_SUBDOMAINS=
# RLS GUC interceptor — MUST be "true" in production (post 20260509 migration).
# Setting it false in prod either breaks every authenticated query (deqah_app role)
# or silently bypasses RLS (OWNER role). Both are rejected at boot.
RLS_GUC_INTERCEPTOR_ENABLED=false

# --- Auth bootstrap ---
# Initial super-admin password. Min 16 chars. In production the literal values
# 'Admin@2026', 'admin', 'password' are rejected.
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password
# Comma-separated emails allowed by OwnerOnlyGuard (refund / waive / grant-credit /
# change-plan / force-charge / billing-settings updates). Fails CLOSED if blank.
OWNER_EMAILS=
# Base URL used to build password-reset links sent in email. Defaults to DASHBOARD_PUBLIC_URL. # optional
PASSWORD_RESET_BASE_URL=http://localhost:5103

# --- Captcha (OTP bot protection) ---
# Provider: noop | hcaptcha | turnstile. 'noop' is FORBIDDEN in production.
CAPTCHA_PROVIDER=noop
# hCaptcha server-side secret. Required only when CAPTCHA_PROVIDER=hcaptcha. # optional
HCAPTCHA_SECRET=
# Cloudflare Turnstile server-side secret. Required only when CAPTCHA_PROVIDER=turnstile. # optional
TURNSTILE_SECRET=

# --- Authentica (platform OTP) ---
# Single API key shared across all tenants. Distinct from per-tenant booking SMS.
# https://portal.authentica.sa/settings/apikeys/  # required in production
AUTHENTICA_API_KEY=
# Authentica REST base URL. # optional
AUTHENTICA_BASE_URL=https://api.authentica.sa
# Default OTP message template ID registered in the Authentica portal. # optional
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# --- Email (Resend + SMTP fallback) ---
# Resend API key (platform transactional email). Skipped silently in dev if blank;
# throws on startup in production. https://resend.com/api-keys  # required in production
RESEND_API_KEY=
# RFC 5322 From header for platform emails (e.g. Deqah <noreply@mail.deqah.app>). # optional
RESEND_FROM="Deqah <noreply@mail.deqah.app>"
# Reply-To header for platform emails. # optional
RESEND_REPLY_TO=support@deqah.app
# Optional generic SMTP fallback (per-tenant SMTP lives in OrganizationEmailConfig). # optional
SMTP_HOST=
# SMTP port. # optional
SMTP_PORT=587
# SMTP auth user. # optional
SMTP_USER=
# SMTP auth password. # optional
SMTP_PASS=
# SMTP envelope From email. # optional
SMTP_FROM=

# --- Push notifications (FCM) ---
# Firebase Cloud Messaging project ID. # optional
FCM_PROJECT_ID=
# FCM service-account client_email. # optional
FCM_CLIENT_EMAIL=
# FCM service-account private_key (PEM with literal \n line breaks if quoted). # optional
FCM_PRIVATE_KEY=

# --- Platform Moyasar (charges clinics for SaaS subscriptions) ---
# Distinct from OrganizationPaymentConfig.moyasar* (per-tenant Moyasar, Plan 02e).
# Use sk_test_* in dev/test. # required in production
MOYASAR_PLATFORM_SECRET_KEY=sk_test_change-me
# HMAC secret used to verify Moyasar webhook signatures. Min 16 chars. # required in production
MOYASAR_PLATFORM_WEBHOOK_SECRET=dev-moyasar-webhook-secret-change-me

# --- SaaS billing ---
# Free-trial length granted on org creation (0-90 days). # optional
SAAS_TRIAL_DAYS=14
# Past-due grace period before suspension (0-30 days). # optional
SAAS_GRACE_PERIOD_DAYS=2
# Master switch for the nightly billing cron (renewals, dunning). # optional
BILLING_CRON_ENABLED=false
# Slug of the plan auto-assigned to orgs without an active subscription.
# Must match an existing Plan.slug after seed. Format: ^[A-Z][A-Z0-9_]{1,31}$.
PLATFORM_DEFAULT_PLAN_SLUG=BASIC
# Base URL used by billing emails for tenant-dashboard CTAs. # optional
PLATFORM_DASHBOARD_URL=http://localhost:5103
# Base URL used by billing emails for super-admin CTAs. # optional
PLATFORM_ADMIN_URL=http://localhost:5104
# Operations email shown on dunning notices and receipts. # optional
PLATFORM_OPS_EMAIL=ops@deqah.app

# --- Zoho Invoice (per-tenant + platform) ---
# Shared OAuth client used by every tenant's Zoho integration.
# https://api-console.zoho.com — Server-based Application, scope ZohoInvoice.fullaccess.all
# # required in production
ZOHO_OAUTH_CLIENT_ID=
# Zoho OAuth client secret. # required in production
ZOHO_OAUTH_CLIENT_SECRET=
# Redirect URI registered in the Zoho client config. Must EXACTLY match.
# HTTPS required in production. # required in production
ZOHO_OAUTH_REDIRECT_URI=http://localhost:5100/dashboard/integrations/zoho/callback
# Deqah's OWN Zoho organization ID (for SaaS->tenant invoicing). Blank disables it. # optional
ZOHO_PLATFORM_ORGANIZATION_ID=
# Refresh token for Deqah's platform Zoho org. # optional
ZOHO_PLATFORM_REFRESH_TOKEN=
# Zoho data center: com | sa | eu | in | au | jp | ca. # optional
ZOHO_PLATFORM_DC=sa
# HMAC secret used to verify incoming Zoho webhook signatures on the platform org. # optional
ZOHO_PLATFORM_WEBHOOK_SECRET=

# --- AI (embeddings + chat) ---
# OpenAI API key (used only for embeddings today). # optional
OPENAI_API_KEY=
# Embedding model name. # optional
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OpenRouter API key (used for chat/completion via the AI BC). # optional
OPENROUTER_API_KEY=
# OpenRouter base URL. # optional
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default chat model slug on OpenRouter. # optional
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku

# --- Sentry / observability ---
# Sentry/GlitchTip DSN. Blank silently disables error reporting. # optional
SENTRY_DSN=
# Release identifier surfaced in Sentry events. # optional
SENTRY_RELEASE=

# --- SMS webhook ---
# Public origin registered with SMS providers for delivery-receipt callbacks.
# Defaults to API_PUBLIC_URL when blank. # optional
SMS_WEBHOOK_URL_BASE=

# --- Branding ---
# Comma-separated hostnames (no protocol) allowed in tenant-supplied logo, favicon,
# font URLs and url(...) references inside customCss. Subdomains of listed hosts are
# allowed. Defaults to MINIO_ENDPOINT when blank. # optional
BRANDING_ALLOWED_ASSET_HOSTS=localhost

# --- Internal metrics endpoint ---
# Bearer token required by the /internal/metrics endpoint. Min 32 chars in prod. # required in production
INTERNAL_METRICS_TOKEN=
# Comma-separated CIDRs/IPs allowed to call /internal/metrics. # required in production
INTERNAL_METRICS_ALLOWED_IPS=127.0.0.1,::1

# --- Feature flags ---
# Enable Plan version-pinning (subscriptions stay on the version they signed up to). # optional
PLAN_VERSIONING_ENABLED=false
# Auto-charge stored card the moment a trial ends. # optional
TRIAL_AUTO_CHARGE_ENABLED=false
# Strict coupon validation (enforce stacking rules + per-customer limits). # optional
COUPON_STRICT_ENABLED=false
# Enable the booking-expiry cron that releases unconfirmed slots. # optional
BOOKING_EXPIRY_CRON_ENABLED=false

# --- Test / dev only (NEVER set in production unless noted) ---
# Marks the process as a CI E2E run. Refused implicitly by captcha.verifier in prod. # optional
E2E_TEST=false
# Bypass all rate limits. MUST be 'false' in production (Joi rejects otherwise). # optional
THROTTLER_DISABLED=false
# When 'true' the Nest bootstrap writes openapi.json to disk and exits. # optional
WRITE_OPENAPI_SPEC=false
# TEMPORARY (2026-05-07): downgrades Zoho + hCaptcha to optional in prod so the
# platform can boot before real credentials land. Remove once those keys are populated.
# # optional
RELAX_PROD_VALIDATION=false
